{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "lib": ["ES2017", "DOM"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "bot.js",
    "src/**/*",
    "utils/**/*",
    "cache/**/*.js",
    "prisma/**/*.ts",
    "prisma/prismadb.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist"
  ]
}
